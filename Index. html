
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Formulário de Aluguel - Ylma Cake's Festa</title>
    <style>
        :root {
            --rosa-principal: #d8547c;
            --rosa-claro: #fdf2f5;
            --borda: #eec1cc;
        }
        body { font-family: 'Segoe UI', Arial, sans-serif; margin: 0; padding: 20px; background-color: #f0f0f0; }
        .folha {
            background: white;
            width: 210mm;
            min-height: 297mm;
            margin: auto;
            padding: 20px;
            box-sizing: border-box;
            border: 1px solid #ccc;
            position: relative;
            background-image: url('https://github.com/Ylma2025/ylmacakesfesta/blob/main/1774000007937.png'); /* Substitua pelo link da sua logo no GitHub */
            background-repeat: no-repeat;
            background-position: center;
            background-size: 60%;
            background-attachment: fixed;
        }
        /* Efeito de Marca d'água */
        .folha::before {
            content: "";
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(255, 255, 255, 0.85); /* Clareia a logo no fundo */
            z-index: 1;
        }
        .conteudo { position: relative; z-index: 2; }
        header { text-align: center; border: 2px solid var(--rosa-principal); padding: 10px; border-radius: 10px; margin-bottom: 20px; }
        h1 { color: var(--rosa-principal); margin: 0; text-transform: uppercase; font-size: 22px; }
        h2 { color: var(--rosa-principal); font-size: 16px; margin-top: 5px; }
        .sessao { margin-bottom: 15px; }
        .campo { margin-bottom: 8px; font-size: 14px; color: #333; }
        input[type="text"] { border: none; border-bottom: 1px solid #aaa; width: 70%; outline: none; background: transparent; }
        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th { background-color: var(--rosa-principal); color: white; padding: 8px; font-size: 13px; }
        td { border: 1px solid var(--borda); padding: 8px; height: 25px; }
        .rodape { margin-top: 30px; display: flex; justify-content: space-between; text-align: center; }
        .assinatura { border-top: 1px solid #000; width: 45%; margin-top: 40px; font-size: 12px; }
        
        @media print {
            body { background: none; padding: 0; }
            .folha { border: none; box-shadow: none; margin: 0; }
            button { display: none; }
        }
    </style>
</head>
<body>

<div style="text-align: center; margin-bottom: 10px;">
    <button onclick="window.print()" style="padding: 10px 20px; background: #d8547c; color: white; border: none; border-radius: 5px; cursor: pointer;">
        Imprimir ou Salvar em PDF
    </button>
</div>

<div class="folha">
    <div class="conteudo">
        <header>
            <h1>Ylma Cake's Festa</h1>
            <h2>FORMULÁRIO DE ALUGUEL DE ARTIGOS</h2>
        </header>

        <div class="sessao">
            <div class="campo"><strong>Cliente:</strong> <input type="text" style="width: 85%;"></div>
            <div class="campo"><strong>CPF/CNPJ:</strong> <input type="text" style="width: 30%;"> <strong>Tel:</strong> <input type="text" style="width: 40%;"></div>
            <div class="campo"><strong>Cidade/Endereço:</strong> <input type="text" style="width: 73%;"></div>
        </div>

        <table>
            <thead>
                <tr>
                    <th width="50%">DESCRIÇÃO DOS ITENS</th>
                    <th width="10%">QTD</th>
                    <th width="20%">VALOR UNIT.</th>
                    <th width="20%">TOTAL</th>
                </tr>
            </thead>
            <tbody>
                <tr><td></td><td></td><td></td><td></td></tr>
                <tr><td></td><td></td><td></td><td></td></tr>
                <tr><td></td><td></td><td></td><td></td></tr>
                <tr><td></td><td></td><td></td><td></td></tr>
                <tr><td></td><td></td><td></td><td></td></tr>
                <tr><td></td><td></td><td></td><td></td></tr>
                <tr><td></td><td></td><td></td><td></td></tr>
                <tr><td></td><td></td><td></td><td></td></tr>
                <tr><td></td><td></td><td></td><td></td></tr>
                <tr><td></td><td></td><td></td><td></td></tr>
                <tr><td></td><td></td><td></td><td></td></tr>
                <tr><td></td><td></td><td></td><td></td></tr>
                <tr><td></td><td></td><td></td><td></td></tr>
                <tr><td></td><td></td><td></td><td></td></tr>
                <tr><td></td><td></td><td></td><td></td></tr>
            </tbody>
        </table>

        <div style="margin-top: 15px; text-align: right; font-weight: bold; color: var(--rosa-principal);">
            VALOR TOTAL: R$ _________________ | CAUÇÃO: R$ _________________
        </div>

        <div class="rodape">
            <div class="assinatura"><br>Assinatura do Cliente</div>
            <div class="assinatura"><br>Ylma Cake's Festa</div>
        </div>
    </div>
</div>

</body>
</html>
